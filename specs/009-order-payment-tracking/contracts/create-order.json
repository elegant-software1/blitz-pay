{
  "contract": "Create Order — Shopper",
  "version": "v1",
  "note": "Shopper-created orders trigger immediate payment initiation via the chosen provider. The order starts in CREATED and transitions to PAYMENT_INITIATED within the same request.",
  "endpoints": [
    {
      "id": "shopper-create-order",
      "method": "POST",
      "path": "/v1/orders",
      "description": "Creates an order from merchant products and immediately initiates payment via the selected provider. Returns the canonical order reference and a provider-specific payment reference.",
      "request": {
        "contentType": "application/json",
        "body": {
          "items": {
            "type": "array",
            "required": true,
            "items": {
              "productId": {
                "type": "string",
                "format": "uuid",
                "required": true
              },
              "quantity": {
                "type": "integer",
                "required": true,
                "minimum": 1
              }
            }
          },
          "paymentMethod": {
            "type": "string",
            "required": true,
            "enum": ["TRUELAYER", "QRPAY", "BRAINTREE", "STRIPE"],
            "description": "Determines which payment provider is invoked immediately after order creation."
          }
        }
      },
      "responses": {
        "201": {
          "contentType": "application/json",
          "body": {
            "orderId": {
              "type": "string",
              "description": "Canonical business reference for the order and all related payments."
            },
            "merchantId": {
              "type": "string",
              "format": "uuid"
            },
            "branchId": {
              "type": "string",
              "format": "uuid",
              "required": false
            },
            "status": {
              "type": "string",
              "enum": ["CREATED", "PAYMENT_INITIATED", "PAID", "FAILED", "CANCELLED"],
              "description": "Expected to be PAYMENT_INITIATED on successful creation + payment dispatch."
            },
            "creatorType": {
              "type": "string",
              "enum": ["SHOPPER"]
            },
            "currency": {
              "type": "string"
            },
            "totalAmountMinor": {
              "type": "integer"
            },
            "paymentRetryAllowed": {
              "type": "boolean"
            },
            "paymentReference": {
              "type": "object",
              "required": false,
              "description": "Provider-specific payment reference (e.g., TrueLayer payment link, Braintree client token). Shape varies by paymentMethod.",
              "properties": {
                "provider": { "type": "string" },
                "paymentRequestId": { "type": "string", "format": "uuid" },
                "providerPaymentId": { "type": "string", "required": false }
              }
            },
            "items": {
              "type": "array",
              "items": {
                "productId": { "type": "string", "format": "uuid" },
                "name": { "type": "string" },
                "quantity": { "type": "integer" },
                "unitPriceMinor": { "type": "integer" },
                "lineTotalMinor": { "type": "integer" }
              }
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "400": {
          "description": "The order request is malformed, empty, contains invalid quantities, or is missing paymentMethod."
        },
        "404": {
          "description": "One or more referenced products are unknown."
        },
        "422": {
          "description": "Validation failed. Response body lists every invalid product reference and the specific rejection reason (inactive, wrong merchant, etc.)."
        }
      }
    }
  ]
}
