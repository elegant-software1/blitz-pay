{
  "contract": "List Shopper Orders",
  "version": "v1",
  "endpoints": [
    {
      "id": "list-shopper-orders",
      "method": "GET",
      "path": "/v1/orders",
      "description": "Returns a list of order summaries for the authenticated shopper. Defaults to orders from the last 7 days.",
      "request": {
        "queryParams": {
          "from": {
            "type": "string",
            "format": "date",
            "required": false,
            "description": "Start of date range (inclusive). Defaults to 7 days ago."
          },
          "to": {
            "type": "string",
            "format": "date",
            "required": false,
            "description": "End of date range (inclusive). Defaults to today."
          }
        }
      },
      "responses": {
        "200": {
          "contentType": "application/json",
          "body": {
            "orders": {
              "type": "array",
              "description": "Summary records only; use GET /v1/orders/{orderId} for line-item detail.",
              "items": {
                "orderId": { "type": "string" },
                "merchantId": { "type": "string", "format": "uuid" },
                "branchId": { "type": "string", "format": "uuid", "required": false },
                "status": {
                  "type": "string",
                  "enum": ["CREATED", "PAYMENT_INITIATED", "PAID", "FAILED", "CANCELLED"]
                },
                "currency": { "type": "string" },
                "totalAmountMinor": { "type": "integer" },
                "paymentRetryAllowed": { "type": "boolean" },
                "createdAt": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    }
  ]
}
